# Copy to .env (the bridge looks at ./.env, src/.env, and
# ~/.config/tapo-bridge/.env in that order).
#
# Per-camera config (IP, model, ONVIF ports) lives in config/cameras.yml,
# not here. This file holds the shared TP-Link cloud account credentials
# and the mediamtx / network settings that apply to all cameras.

# --- TP-Link cloud account that owns the camera(s) ----------------------
CAM_USER=your.cloud.email@example.com
CAM_PASS=YourTPLinkCloudPassword

# --- internal RTSP server (mediamtx) ------------------------------------
# Leave RTSP_HOST as 127.0.0.1 — the publish user is restricted to
# loopback in mediamtx.yml.template; pointing this elsewhere will be
# rejected.
RTSP_HOST=127.0.0.1
RTSP_PORT=8555
# The bridge publishes via 127.0.0.1 with publish/publish; mediamtx's
# IP allowlist locks that user to loopback so it can stay hardcoded.
PUBLISH_USER=publish
PUBLISH_PASS=publish

# --- external read credentials (UniFi / Scrypted / VLC use these) -------
# Pick a strong password; this IS exposed to the LAN.
READ_USER=unifi
READ_PASS=ChangeMeToSomethingStrong

# --- public-facing host (must be reachable by your UniFi/Scrypted) ------
PUBLIC_HOST=192.168.1.50

# --- ports --------------------------------------------------------------
SNAPSHOT_PORT=8683
# ONVIF ports are per-camera in config/cameras.yml.

# --- binaries (override if not at default homebrew location) ------------
PYTHON_BIN="$HOME/Library/Application Support/tapo-onvif/venv/bin/python"
FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
MEDIAMTX_BIN=/opt/homebrew/bin/mediamtx
